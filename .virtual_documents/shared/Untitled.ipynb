import pandas as pd

dga_df = pd.read_csv(
    "s3://mypracticeaws-s3bucket-ainisa/data/dga_websites/dga_websites.csv"
)

legit_df = pd.read_csv(
    "s3://mypracticeaws-s3bucket-ainisa/data/legit_websites/legit_websites.csv"
)

dga_df['label'] = 1
legit_df['label'] = 0

df = pd.concat([dga_df, legit_df], ignore_index=True)
print(df.head)


import boto3

s3 = boto3.client('s3')

obj = s3.get_object(
    Bucket='mypracticeaws-s3bucket-ainisa',
    Key='data/words/words.txt'
)

words = obj['Body'].read().decode('utf-8').splitlines()

print(words[:10])



