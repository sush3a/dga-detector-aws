import math
from collections import Counter

def calc_entropy(s):
    if not s:
        return 0
    p, lns = Counter(s), float(len(s))
    return -sum(count/lns * math.log(count/lns, 2) for count in p.values())

# 1. Ensure domain is string
df['domain'] = df['domain'].astype(str)

# 2. Calculate Length (Fixed the AttributeError here)
df['length'] = df['domain'].str.len()

# 3. Calculate Entropy
df['entropy'] = df['domain'].apply(calc_entropy)

# 4. Preview the results
print(df[['domain', 'length', 'entropy', 'label']].head())


import numpy as np
import pandas as pd

# 1. Select only the numerical features and the label
# We must drop the 'domain' and 'class' text columns
final_df = df[['label', 'length', 'entropy']] 

# 2. Shuffle and Split the data (80% Train, 20% Validation)
# Shuffling is critical so the model doesn't see all 'DGA' then all 'Legit'
train_data, val_data = np.split(
    final_df.sample(frac=1, random_state=42), 
    [int(0.8 * len(final_df))]
)

# 3. Save to local CSVs in SageMaker's required format
# header=False and index=False are MANDATORY for SageMaker XGBoost
train_data.to_csv('train.csv', header=False, index=False)
val_data.to_csv('validation.csv', header=False, index=False)

print(f"Training rows: {len(train_data)}")
print(f"Validation rows: {len(val_data)}")


import sagemaker
import boto3

sess = sagemaker.Session()
bucket = 'mypracticeaws-s3bucket-ainisa'
prefix = 'dga-detection-output'

# Uploading the files to a specific folder in your bucket
train_s3_path = sess.upload_data(path='train.csv', bucket=bucket, key_prefix=prefix + '/train')
validation_s3_path = sess.upload_data(path='validation.csv', bucket=bucket, key_prefix=prefix + '/validation')

print(f"Train data is now at: {train_s3_path}")
print(f"Validation data is now at: {validation_s3_path}")


import sagemaker
from sagemaker import image_uris
from sagemaker.estimator import Estimator
from sagemaker.inputs import TrainingInput

# 1. Get the XGBoost Container URI
container = image_uris.retrieve(
    framework='xgboost', 
    region=sess.boto_region_name, 
    version='1.7-1' # Latest stable version
)

# 2. Define the Estimator (The Training "Job Description")
xgb_model = Estimator(
    image_uri=container,
    role=sagemaker.get_execution_role(), 
    instance_count=1, 
    instance_type='ml.m5.xlarge', # A standard CPU instance for training
    output_path=f's3://{bucket}/{prefix}/output',
    sagemaker_session=sess
)

# 3. Set Hyperparameters (The "Settings" for the algorithm)
xgb_model.set_hyperparameters(
    max_depth=5,
    eta=0.2,
    gamma=4,
    min_child_weight=6,
    subsample=0.7,
    objective='binary:logistic', # Since we are doing 0 (Legit) vs 1 (DGA)
    num_round=50
)

# 4. Map the S3 data to the Training Job
train_input = TrainingInput(s3_data=train_s3_path, content_type='csv')
val_input = TrainingInput(s3_data=validation_s3_path, content_type='csv')

# 5. START TRAINING
print("Starting training job...")
xgb_model.fit({'train': train_input, 'validation': val_input})


# Try ml.m4.xlarge first, as it's the most common available type
try:
    transformer = xgb_model.transformer(
        instance_count=1, 
        instance_type='ml.m4.xlarge' 
    )
    
    print("Starting Batch Transform...")
    transformer.transform(validation_s3_path, content_type='text/csv')
    transformer.wait() # This will show the progress bar
    print(f"Success! Results saved to: {transformer.output_path}")

except Exception as e:
    print(f"m4.xlarge failed, trying t2.medium: {e}")
    # If m4 fails, t2.medium is almost always open
    transformer = xgb_model.transformer(
        instance_count=1, 
        instance_type='ml.t2.medium'
    )
    transformer.transform(validation_s3_path, content_type='text/csv')
    transformer.wait()


